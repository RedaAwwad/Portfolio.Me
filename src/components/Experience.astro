---
// Experience + YouTube Section
const timeline = [
  {
    period: '2024 — Present',
    title: 'Full-Stack Software Engineer',
    description: 'Building production-grade applications for clients worldwide. Focused on clean code, scalability and performance.',
  },
  {
    period: '2022 — 2023',
    title: 'Software Engineer',
    description: 'Worked with startups to build SaaS platforms and internal tools using modern JS and php stacks.',
  },
  {
    period: '2020 — 2022',
    title: 'Frontend Developer',
    description: 'Built pixel-perfect UIs using React, Vue, JavaScript frameworks and component libraries.',
  },
];

const stats = [
  { value: '232+', label: 'Subscribers' },
  { value: '22+', label: 'Videos' },
  { value: '12K+', label: 'Total Views' },
];
---

<section id="experience" class="py-20 md:py-28 bg-card/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left: My Journey -->
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-accent font-medium mb-3">EXPERIENCE</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-10">My Journey</h2>

        <!-- Timeline -->
        <div class="relative pt-6">
          <!-- Timeline line -->
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border"></div>

          <div class="space-y-10">
            {timeline.map((item, index) => (
              <div class="relative pl-8">
                <!-- Dot -->
                <div class={`absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full border-2 ${index === 0 ? 'border-accent bg-accent/20' : 'border-border bg-card'}`}></div>
                
                <!-- Content -->
                <div>
                  <span class="text-xs text-accent font-medium">{item.period}</span>
                  <h3 class="text-lg font-semibold mt-1 mb-2">{item.title}</h3>
                  <p class="text-sm text-text-secondary leading-relaxed">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- View Full Resume -->
        <a href="https://www.linkedin.com/in/redaawwad" target="_blank" class="inline-flex items-center gap-2 text-accent text-sm font-medium mt-8 hover:underline cursor-pointer">
          View Full Resume
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: YouTube -->
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-accent font-medium mb-3">TEACHING & COMMUNITY</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-10">Sharing Knowledge on YouTube</h2>

        <!-- Channel Card -->
        <div class="bg-card border border-border rounded-2xl p-4 sm:p-6 mb-6">
          <div class="flex items-center gap-4 justify-between">
            <div class="flex items-center gap-4 mb-4">
              <!-- Channel Avatar -->
              <div class="w-14 h-14 rounded-full overflow-hidden bg-surface border border-border flex items-center justify-center">
                <img src="/images/me_codemy.png" alt="Codemy Logo" class="w-full h-full">
              </div>
              <div>
                <h3 class="font-semibold text-lg">Codemy
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline text-red-500 ml-1" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" />
                  </svg>
                </h3>
                <a href="https://www.youtube.com/@reda.codemy" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text-primary">@reda.codemy</a>
              </div>
            </div>
  
            <!-- Subscribe Button -->
            <a href="https://www.youtube.com/@reda.codemy" target="_blank" class="inline-flex items-center gap-2 group border border-border bg-red-600 hover:opacity-75 text-sm font-medium px-4 py-2 rounded-lg transition-opacity duration-200 cursor-pointer">
              <svg class="w-5 h-5 text-red-100" viewBox="0 -3 20 20" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Dribbble-Light-Preview" transform="translate(-300.000000, -7442.000000)" fill="currentColor"><g transform="translate(56.000000, 160.000000)"><path d="M251.988432,7291.58588 L251.988432,7285.97425 C253.980638,7286.91168 255.523602,7287.8172 257.348463,7288.79353 C255.843351,7289.62824 253.980638,7290.56468 251.988432,7291.58588 M263.090998,7283.18289 C262.747343,7282.73013 262.161634,7282.37809 261.538073,7282.26141 C259.705243,7281.91336 248.270974,7281.91237 246.439141,7282.26141 C245.939097,7282.35515 245.493839,7282.58153 245.111335,7282.93357 C243.49964,7284.42947 244.004664,7292.45151 244.393145,7293.75096 C244.556505,7294.31342 244.767679,7294.71931 245.033639,7294.98558 C245.376298,7295.33761 245.845463,7295.57995 246.384355,7295.68865 C247.893451,7296.0008 255.668037,7296.17532 261.506198,7295.73552 C262.044094,7295.64178 262.520231,7295.39147 262.895762,7295.02447 C264.385932,7293.53455 264.28433,7285.06174 263.090998,7283.18289"></path>
            </g></g></g></svg>
              Subscribe
            </a>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Teaching web development best practices through hands-on tutorials.
          </p>

        <!-- Video Thumbnail -->
        <a href="https://youtu.be/qaQ9IN7rl2Y" target="_blank" class="relative rounded-2xl overflow-hidden border border-border group cursor-pointer w-full aspect-video flex items-center justify-center">
          <img
            src="/images/last_video.png"
            alt="Modern Web Development Best Practices"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <!-- Play overlay -->
          <span class="absolute inset-0 bg-black/30  group-hover:bg-black/40 transition-colors duration-300">
          </span>
          <span class="w-14 h-14 absolute z-20 bg-white rounded-full flex items-center justify-center shadow-2xl group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-red-600 fill-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.4086 9.35258C22.5305 10.5065 22.5305 13.4935 20.4086 14.6474L7.59662 21.6145C5.53435 22.736 3 21.2763 3 18.9671L3 5.0329C3 2.72368 5.53435 1.26402 7.59661 2.38548L20.4086 9.35258Z" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
        </a>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mt-4">
          {stats.map((stat) => (
            <div class="text-center">
              <p class="text-xl font-bold text-accent">{stat.value}</p>
              <p class="text-xs text-text-secondary mt-1">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
