---
// Client Logos Bar
const clients = [
  { name: 'Google', logo: 'google' },
  { name: 'Microsoft', logo: 'microsoft' },
  { name: 'Redis', logo: 'redis' },
  { name: 'AWS', logo: 'aws' },
  { name: 'Supabase', logo: 'supabase' },
  { name: 'MongoDB', logo: 'mongodb' },
];
---

<section class="py-12 border-y border-border bg-card/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
      <p class="text-sm text-text-secondary whitespace-nowrap font-medium">Worked with amazing clients</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 flex-1">
        <!-- Google -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <svg class="w-5 h-5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="text-sm font-medium">Google</span>
        </div>

        <!-- Microsoft -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <svg class="w-4 h-4 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M0 0h11.5v11.5H0V0zm12.5 0H24v11.5H12.5V0zM0 12.5h11.5V24H0V12.5zm12.5 0H24V24H12.5V12.5z"/>
          </svg>
          <span class="text-sm font-medium">Microsoft</span>
        </div>

        <!-- Redis -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <svg class="w-5 h-5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.005c-.062.574-1.727 1.237-3.467 1.852-1.74.616-4.055 1.437-4.114 2.035-.06.597 2.355 1.178 2.355 1.836 0 .658-2.669 1.498-4.467 2.088-1.798.59-3.09.758-5.307.758s-3.509-.168-5.307-.758C1.895 19.226-.774 18.386-.774 17.728c0-.658 2.415-1.239 2.355-1.836-.06-.598-2.374-1.419-4.114-2.035C-4.273 13.242-5.938 12.579-6 12.005 "/>
          </svg>
          <span class="text-sm font-medium">Redis</span>
        </div>

        <!-- AWS -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <span class="text-lg font-bold opacity-60 group-hover:opacity-100 transition-opacity tracking-wide">aws</span>
        </div>

        <!-- Supabase -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <svg class="w-5 h-5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21.362 9.354H12V.396a.396.396 0 00-.716-.233L2.203 12.424l-.401.562a1.04 1.04 0 00.836 1.66H12v8.958a.396.396 0 00.716.233l9.081-12.261.401-.562a1.04 1.04 0 00-.836-1.66z"/>
          </svg>
          <span class="text-sm font-medium">Supabase</span>
        </div>

        <!-- MongoDB -->
        <div class="flex items-center gap-2 text-text-muted hover:text-white transition-colors duration-200 cursor-pointer group">
          <svg class="w-4 h-4 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.193 9.555c-1.264-5.58-4.252-7.414-4.573-8.115-.28-.394-.53-.954-.735-1.44-.036.495-.055.685-.523 1.184-.723.566-4.438 3.682-4.74 10.02-.282 5.912 4.27 9.435 4.888 9.884l.07.05A73.49 73.49 0 0111.91 24h.481c.114-1.032.284-2.056.51-3.07.417-.296.604-.463.85-.693a11.342 11.342 0 003.639-8.464c.01-.814-.103-1.662-.197-2.218z"/>
          </svg>
          <span class="text-sm font-medium">MongoDB</span>
        </div>
      </div>
    </div>
  </div>
</section>
