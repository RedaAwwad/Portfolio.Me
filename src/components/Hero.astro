---
// Hero Section
---

<section id="home" class="relative min-h-[100dvh] pt-20 pb-16 lg:pt-36 md:pb-24 overflow-hidden">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent pointer-events-none"></div>
  <div class="absolute top-20 right-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>
  
  <!-- Perspective gold dot grid overlay -->
  <div class="absolute bottom-0 left-0 right-0 h-48 bg-[radial-gradient(var(--color-accent-dim)_1.5px,transparent_1.5px)] [background-size:24px_24px] [mask-image:linear-gradient(to_bottom,transparent,white)] opacity-35 pointer-events-none z-0"></div>

  <div class="absolute top-0 bottom-0 left-0 right-0 z-10 w-full h-full">
    <img
      src="/images/hero.png"
      alt="Reda Awwad — Full-Stack Developer"
      class="w-full h-full object-cover object-bottom-right sm:object-center"
      loading="eager"
    />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left Column -->
      <div class="relative z-10">
        <!-- Available Badge -->
        <div class="inline-flex items-center gap-2 bg-card border border-border rounded-full px-4 py-2 mb-8">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-sm text-text-secondary">Available for freelance work</span>
        </div>

        <!-- Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-bold leading-tight mb-6">
          I build scalable web
          <br />
          <span class="bg-gradient-to-r from-accent to-amber-400 bg-clip-text text-transparent">applications</span> with
          <br />
          clean code &amp;
          <span class="bg-gradient-to-r from-accent to-amber-400 bg-clip-text text-transparent">best practices</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-text-secondary text-base md:text-lg max-w-lg mb-8 leading-relaxed">
          Software engineer focused on building modern, performant & maintainable web applications. I turn business ideas into working software products.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <a href="#contact" class="inline-flex items-center gap-2 bg-accent text-dark font-semibold px-6 py-3.5 rounded-lg hover:bg-accent-hover transition-all duration-200 cursor-pointer">
            Hire Me
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a href="#portfolio" class="inline-flex items-center gap-2 bg-transparent text-white font-semibold px-6 py-3.5 rounded-lg border border-border hover:border-accent/50 transition-all duration-200 cursor-pointer">
            View My Work
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right Column — Photo + Code Snippets + Badges -->
      <div class="relative flex justify-center lg:justify-end z-10 w-full">
        <!-- Main Photo Container (borderless, blends with dark background) -->
        <div class="relative w-full max-w-[320px] sm:max-w-[400px] aspect-[4/5] flex items-end justify-center">
          

          <!-- ==================== FLOATING SERVICE BADGES ==================== -->

                    <!-- 1. Transfer Idea Badge (Top Right) -->
          <div class="absolute top-0 sm:top-0 -left-3 sm:left-auto sm:-right-6 md:-right-10 bg-[#0C0C0E]/90 backdrop-blur-xl border border-white/5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2.5 flex items-center gap-2 sm:gap-3 shadow-[0_15px_30px_rgba(245,166,35,0.15)] border-t border-white/10 hover:border-[#F5A623]/30 hover:scale-105 transition-all duration-300 group cursor-pointer z-20 animate-float" style="animation-delay: 0.8s;">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-[#F5A623]/10 border border-[#F5A623]/20 flex items-center justify-center text-accent group-hover:bg-[#F5A623]/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <span class="text-[10px] sm:text-xs font-semibold text-white tracking-wide">Transfer Idea into Software</span>
          </div>

          <!-- 2. Clean Code Badge (Top Left) -->
          <div class="absolute top-[10%] sm:top-[20%] -right-3 sm:-right-6 md:-right-10 bg-[#0C0C0E]/90 backdrop-blur-xl border border-white/5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2.5 flex items-center gap-2 sm:gap-3 shadow-[0_15px_30px_rgba(16,185,129,0.15)] border-t border-white/10 hover:border-emerald-500/30 hover:scale-105 transition-all duration-300 group cursor-pointer z-20 animate-float" style="animation-delay: 0s;">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 group-hover:bg-emerald-500/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="text-[10px] sm:text-xs font-semibold text-white tracking-wide">Clean Code</span>
          </div>



          <!-- 3. Great Experience Badge (Middle Left) -->
          <div class="absolute top-[25%] sm:top-[40%] -left-3 sm:left-auto sm:right-16 bg-[#0C0C0E]/90 backdrop-blur-xl border border-white/5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2.5 flex items-center gap-2 sm:gap-3 shadow-[0_15px_30px_rgba(6,182,212,0.15)] border-t border-white/10 hover:border-cyan-500/30 hover:scale-105 transition-all duration-300 group cursor-pointer z-20 animate-float" style="animation-delay: 1.6s;">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 group-hover:bg-cyan-500/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <span class="text-[10px] sm:text-xs font-semibold text-white tracking-wide">Great Experience</span>
          </div>

          <!-- 4. Scalable Software Badge (Middle Right) -->
          <div class="absolute top-[35%] sm:top-[58%] -right-3 sm:-right-8 bg-[#0C0C0E]/90 backdrop-blur-xl border border-white/5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2.5 flex items-center gap-2 sm:gap-3 shadow-[0_15px_30px_rgba(168,85,247,0.15)] border-t border-white/10 hover:border-purple-500/30 hover:scale-105 transition-all duration-300 group cursor-pointer z-20 animate-float" style="animation-delay: 2.4s;">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 group-hover:bg-purple-500/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
            </div>
            <span class="text-[10px] sm:text-xs font-semibold text-white tracking-wide">Scalable Software</span>
          </div>

          <!-- 5. AI Solutions Badge (Bottom Left/Middle) -->
          <div class="absolute top-[45%] sm:top-[75%] left-2 sm:left-auto sm:right-20 bg-[#0C0C0E]/90 backdrop-blur-xl border border-white/5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2.5 flex items-center gap-2 sm:gap-3 shadow-[0_15px_30px_rgba(244,63,94,0.15)] border-t border-white/10 hover:border-rose-500/30 hover:scale-105 transition-all duration-300 group cursor-pointer z-20 animate-float" style="animation-delay: 3.2s;">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400 group-hover:bg-rose-500/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 5h10a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2z" />
              </svg>
            </div>
            <span class="text-[10px] sm:text-xs font-semibold text-white tracking-wide">AI Solutions</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
