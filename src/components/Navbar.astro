<!-- ==================== MOBILE TOP BAR (logo + CTA, < lg) ==================== -->
<div id="mobile-top-bar" class="fixed top-0 left-0 right-0 z-50 lg:hidden bg-dark/90 backdrop-blur-xl border-b border-border transition-all duration-300">
  <div class="flex items-center justify-between h-14 px-4">
    <a href="#" class="text-xl font-bold cursor-pointer hover:opacity-80 transition-opacity duration-200">
      <span class="text-white">{"{"}</span><span class="text-accent">R</span><span class="text-white">{"}"}</span>
    </a>
    <a href="#contact" class="inline-flex items-center gap-2 bg-accent text-dark font-semibold text-xs px-4 py-2 rounded-lg hover:bg-accent-hover transition-all duration-200 cursor-pointer">
      Hire Me
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
      </svg>
    </a>
  </div>
</div>

<script>
  // Navbar scroll effect (desktop)
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('shadow-lg', 'shadow-[#0A0A0A]/80', 'bg-dark/95');
    } else {
      navbar?.classList.remove('shadow-lg', 'shadow-[#0A0A0A]/80', 'bg-dark/95');
    }
  });

  // Bottom nav + Desktop nav active state tracking via IntersectionObserver
  const sections = document.querySelectorAll('section[id]');
  const bottomLinks = document.querySelectorAll('.bottom-nav-link');
  const desktopLinks = document.querySelectorAll('.nav-link');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          
          // Update mobile bottom nav links
          bottomLinks.forEach((link) => {
            const linkSection = link.getAttribute('data-section');
            const icon = link.querySelector('svg');
            const label = link.querySelector('span');
            
            if (linkSection === id) {
              link.classList.add('active');
              icon?.classList.remove('text-text-muted');
              icon?.classList.add('text-accent');
              label?.classList.remove('text-text-muted');
              label?.classList.add('text-accent');
            } else {
              link.classList.remove('active');
              icon?.classList.remove('text-accent');
              icon?.classList.add('text-text-muted');
              label?.classList.remove('text-accent');
              label?.classList.add('text-text-muted');
            }
          });

          // Update desktop top nav links
          desktopLinks.forEach((link) => {
            const href = link.getAttribute('href');
            if (href === `#${id}`) {
              link.classList.add('active', 'text-accent');
              link.classList.remove('text-text-secondary', 'hover:text-white');
            } else {
              link.classList.remove('active', 'text-accent');
              link.classList.add('text-text-secondary', 'hover:text-white');
            }
          });
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );

  sections.forEach((section) => observer.observe(section));
</script>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 5px;
    height: 5px;
    background-color: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--color-accent);
  }
</style>
